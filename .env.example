API_HTTP_ADDR=:8080
WORKER_HTTP_ADDR=:8081
DATABASE_URL=postgres://postgres:postgres@postgres:5432/durableflow?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_STREAM=durableflow.tasks
REDIS_GROUP=durableflow-workers
REDIS_RECLAIM_MIN_IDLE=30s
REDIS_RECLAIM_COUNT=10
OUTBOX_POLL_INTERVAL=2s
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
VITE_API_BASE_URL=http://localhost:8080
